# Copy to .env for local dev. Do not commit .env.
# In Railway, set these in the project's Variables panel — do not use a .env file there.

# Railway injects PORT automatically. Set it here only for local dev.
PORT=3001

# Comma-separated list of allowed frontend origins.
# Local dev:
FRONTEND_URL=http://localhost:5173
# LAN phone testing (add your machine's local IP alongside localhost):
# FRONTEND_URL=http://localhost:5173,http://192.168.1.11:5173
# Production (Railway Variable — set to your Vercel URL):
# FRONTEND_URL=https://your-app.vercel.app

# Training-mode annotation storage path (optional).
# Leave unset locally — writes go to backend/data/training/.
# On Railway, set to the mount path of the persistent volume, e.g.
#   TRAINING_DATA_DIR=/data/training
# See README → Production storage for volume setup.

# Game Review storage path (optional). Parallel data domain to TRAINING_DATA_DIR.
# Every completed round auto-saves a GameRecord under
#   <GAMES_DATA_DIR>/<roomCreatorUserId>/<isoStamp>-<gameId>.json
# Leave unset locally — writes go to backend/data/games/.
# On Railway, share the same persistent volume:
#   GAMES_DATA_DIR=/data/games

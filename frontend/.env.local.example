# Copy this file to .env.local for LAN / phone testing.
# .env.local is loaded by Vite automatically and overrides .env.
# It is gitignored — safe to put real LAN IPs here.
#
# Replace 192.168.1.11 with your machine's actual LAN IP (run `ipconfig` / `ip a`).
VITE_SOCKET_URL=http://192.168.1.11:3001

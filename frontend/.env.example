# Copy to .env for local dev. Do not commit .env.
# In Vercel, set these in Project → Settings → Environment Variables.

# Supabase — get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend socket URL
# Local dev:
VITE_SOCKET_URL=http://localhost:3001
# LAN phone testing — use .env.local to override (see .env.local.example):
#   VITE_SOCKET_URL=http://192.168.1.11:3001
# Production (Vercel Variable — set to your Railway service URL):
#   VITE_SOCKET_URL=https://your-backend.up.railway.app
